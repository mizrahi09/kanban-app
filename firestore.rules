rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — readable by anyone signed in, writable only by the owner
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /boards/{boardId} {
      function isOwner()  { return request.auth.uid == resource.data.ownerId; }
      function isMember() {
        return resource.data.keys().hasAll(['members'])
            && request.auth.uid in resource.data.members;
      }

      allow read:   if request.auth != null && (isOwner() || isMember());
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (isOwner() || isMember());
      allow delete: if request.auth != null && isOwner();

      match /columns/{columnId} {
        allow read, write: if request.auth != null;
      }

      match /tasks/{taskId} {
        allow read, write: if request.auth != null;

        match /comments/{commentId} {
          allow read:   if request.auth != null;
          allow create: if request.auth != null;
          allow delete: if request.auth != null
                        && resource.data.authorId == request.auth.uid;
        }

        match /subtasks/{subtaskId} {
          allow read, write: if request.auth != null;
        }
      }
    }
  }
}
